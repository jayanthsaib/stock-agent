# ═══════════════════════════════════════════════════════════════════════════
#  Cerebro — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════════════════

# ── Angel One Credentials ────────────────────────────────────────────────────
ANGEL_API_KEY=your_api_key_here
ANGEL_CLIENT_ID=your_client_id_here
ANGEL_MPIN=your_mpin_here
ANGEL_TOTP_SECRET=your_totp_secret_here

# ── Telegram Bot ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Database (leave blank for H2 paper-trading mode) ─────────────────────────
# DB_URL=jdbc:postgresql://localhost:5432/stock_agent
# DB_USER=stock_user
# DB_PASSWORD=your_db_password_here
# DB_DRIVER=org.postgresql.Driver
# DB_DIALECT=org.hibernate.dialect.PostgreSQLDialect
# DDL_AUTO=validate          # set to 'validate' when FLYWAY_ENABLED=true
# FLYWAY_ENABLED=true        # enable on PostgreSQL server; false for local H2

# ── Security ──────────────────────────────────────────────────────────────────
# API_KEY=generate-a-strong-random-string-here
# Leave blank to disable API key auth (safe for local dev only)

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080
